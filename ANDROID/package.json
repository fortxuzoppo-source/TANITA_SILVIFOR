{
  "name": "silvifortanita-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Empaquetado Android de SilviForTANITA.",
  "scripts": {
    "mobile:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-mobile-web.ps1",
    "android:sync": "npm run mobile:prepare && cap sync android",
    "android:open": "cap open android",
    "android:build:debug": "npm run android:sync && cd APK && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0"
  }
}
